{
  "rewrites": [
    {
      "source": "/:shortId([a-zA-Z0-9]+)",
      "destination": "/redirect.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=1, stale-while-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/moovie",
      "destination": "https://moovie-linkshare.vercel.app"
    },
    {
      "source": "/moovie/:path*",
      "destination": "https://moovie-linkshare.vercel.app/:path*"
    },
    {
      "source": "/moovie-app",
      "destination": "https://moovie-app-linkshare.vercel.app/moovie-app"
    },
    {
      "source": "/moovie-app/:path*",
      "destination": "https://moovie-app-linkshare.vercel.app/moovie-app/:path*"
    }
  ]
}